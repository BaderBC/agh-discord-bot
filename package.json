{
  "name": "agh-discord-bot",
  "version": "0.1.0",
  "description": "Discord bot do zarządzania serwerem dla pierwszaków AGH",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "tsx src/scripts/setup.ts",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
