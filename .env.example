# Discord bot credentials
DISCORD_TOKEN=your-bot-token-here

# ID serwera (guild), na którym bot działa
GUILD_ID=your-guild-id-here

# ID aplikacji (potrzebne do rejestracji slash-komend)
CLIENT_ID=your-application-client-id-here

# ID kanału, w którym publikowany jest panel wyboru ról
ROLES_CHANNEL_ID=your-roles-channel-id-here
